# Server
PORT=5001

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dms
DB_USER=root
DB_PASSWORD=

# JWT
JWT_SECRET=your-secret-key

# Alfresco
ALFRESCO_URL=http://alfresco-host/alfresco/api/-default-/public/alfresco/versions/1/nodes
ALFRESCO_ID=<parent-folder-node-id>
ALFRESCO_USERNAME=admin
ALFRESCO_PASSWORD=admin
ALFRESCO_SEARCH_URL=http://alfresco-host/alfresco/api/-default-/public/search/versions/1/search

# Document storage: alfresco (default) or s3 (S3 blobs + Elasticsearch full-text)
STORAGE_BACKEND=alfresco

# Elasticsearch (required when STORAGE_BACKEND=s3 for search)
ELASTICSEARCH_URL=http://localhost:9200
# ELASTICSEARCH_API_KEY=
# ELASTICSEARCH_USERNAME=
# ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX=dms-files

# Text extraction for S3/ES indexing (optional)
# EXTRACTION_MAX_CHARS=250000
# EXTRACTION_MAX_FILE_BYTES=52428800

# Optional – S3 (cover images and STORAGE_BACKEND=s3 document blobs)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_DEFAULT_REGION=
S3_BUCKET=
S3_BUCKET_URL=
# Prefix for document object keys (default: documents/)
# S3_DOCUMENTS_PREFIX=documents/
