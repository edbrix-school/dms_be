# Server
PORT=5001

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dms
DB_USER=root
DB_PASSWORD=

# JWT
# JWT_SECRET should be stored in Base64URL-encoded form
JWT_SECRET=your-secret-key

# Alfresco
ALFRESCO_URL=http://alfresco-host/alfresco/api/-default-/public/alfresco/versions/1/nodes
ALFRESCO_ID=<parent-folder-node-id>
ALFRESCO_USERNAME=admin
ALFRESCO_PASSWORD=admin
ALFRESCO_SEARCH_URL=http://alfresco-host/alfresco/api/-default-/public/search/versions/1/search

# Optional – S3 (cover images)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=
S3_BUCKET_URL=
